{
  "name": "@js-monorepo/server",
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "tsx watch --clear-screen=false ./src/main",
    "db:migrate": "tsx ./bin/migrate",
    "db:seed": "tsx ./bin/seed",
    "build": "tsx ./bin/migrate && tsc ./src/main --outDir ../dist --esModuleInterop",
    "start": "node ../dist/src/main",
    "fix": "npx @biomejs/biome check --write .",
    "test": "jest --verbose"
  },
  "dependencies": {
    "@cloudinary/react": "^1.13.1",
    "@cloudinary/url-gen": "^1.21.0",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-fileupload": "^1.5.1",
    "express-ws": "^5.0.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^6.10.0",
    "papaparse": "^5.4.1",
    "sharp": "^0.33.5",
    "uid": "^2.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-fileupload": "^1.5.1",
    "@types/express-ws": "^3.0.5",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/papaparse": "^5.3.15",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
